{
  "manifest_version": 3,
  "name": "Universal Note + SpeechMiner Time",
  "version": "2.5.3",
  "description": "Fix horizontal scrollbar sync for markers/labels using custom handle viewport mapping; time+text labels; click-to-cycle colors.",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Universal Note"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
